{
  "id": "techgen-dotnet",
  "version": "0.2.3",
  "source": {
    "marketplace": "Hakan-Soysal/codegen-plugin",
    "install": "/plugin marketplace add Hakan-Soysal/codegen-plugin && /plugin install codegen@codegen-tools"
  },
  "invocation": {
    "type": "cli",
    "entry": "dotnet ${CLAUDE_SKILL_DIR}/techgen/Gen.Cli.dll",
    "args": ["manifest", "targetDir", "config"]
  },
  "capability": {
    "languages": ["csharp"],
    "architectures": ["modular-monolith", "vertical-slice"],
    "persistence": ["postgres", "sqlite", "sqlserver", "inmemory"],
    "transports": ["rest"],
    "constructsCovered": [
      "deployable",
      "module",
      "operation",
      "entity",
      "type",
      "error",
      "event",
      "subscription",
      "external",
      "uncharted",
      "boundary-op",
      "calls",
      "visibility",
      "serving",
      "roles",
      "ownership",
      "scopes",
      "validation",
      "rule",
      "note",
      "consistency",
      "permit",
      "guardRef",
      "throws",
      "idempotent",
      "emits",
      "pagination",
      "invariant",
      "compensate",
      "sourceOfTruth",
      "concurrency",
      "ext"
    ]
  },
  "emissionContract": {
    "seamPath": [
      "src/{Module}/{op}Handler.Logic.cs",
      "src/Boundary/{Ext}Client.Logic.cs",
      "src/{Module}/{op}{Trigger}Trigger.Logic.cs",
      "src/{ConsumerModule}/{Event}To{Op}Consumer.Logic.cs"
    ],
    "emptyStubMarker": "doldurulacak",
    "ownedTree": "gen/**",
    "humanTree": ["src/**", "Program.cs", "App.csproj"],
    "handlerSurfaceMap": {
      "operation": "{op}Handler.ExecuteAsync(request, ct) : Task<Result<T>>",
      "validation": "Validation_N",
      "rule": "Rule_N",
      "invariant": "{Entity}Invariants.Invariant_N",
      "throwsFactory": "{op}Handler.{ErrorId}(...) : Result<T>",
      "throwsCatalog": "{op}Handler.ThrowableErrors",
      "auth": ["RequiredRoles", "RequiredScopes", "Ownership"],
      "idempotent": "IdempotencyKeys",
      "boundary": "{Ext}Client.{op}(...) : Task<T>",
      "boundaryValidation": "{Ext}{op}Validation.Validation_N",
      "subscription": "{Event}To{Op}Consumer.HandleAsync(@event, ct) : Task",
      "trigger": "{op}{Trigger}Trigger.StartAsync(ct) : Task",
      "pagination": ["PaginationStrategy", "DefaultPageSize"],
      "consistency": ["ConsistencyRisk", "ConsistencyMode"],
      "resultTaxonomy": ["Success", "NotAuthenticated", "NotAuthorized", "NotValid", "NotProcessable", "ServerError"]
    },
    "canonicalOrder": [
      "idempotency",
      "authz",
      "validation",
      "external-input",
      "rule",
      "entity+invariant",
      "persist",
      "emit",
      "return"
    ],
    "buildReportSchema": {
      "constructs": "[{construct, id, status}] (status: realized | unsupported)",
      "policies": "{name: decision}"
    }
  },
  "gapProtocol": {
    "compliant": true
  },
  "build": {
    "command": "dotnet build {targetDir}/App.csproj",
    "success": "exit 0"
  },
  "conformance": {
    "adapter": "${CLAUDE_SKILL_DIR}/conformance",
    "run": "dotnet ${CLAUDE_SKILL_DIR}/conformance/Conformance.dll {appDll} {specsPath}"
  },
  "audit": {
    "principle": "Bağımsız adversarial denetimden geçmeyen LLM-üretilmiş seam 'bitti' DEĞİL. (Kapı 3)",
    "independence": "denetleyici = seam'i YAZAN ajan DEĞİL; ayrı/temiz bağlam (subagent). Yalnız seam kodu + contract/gen yüzeyini görür, filler'ın muhakemesini DEĞİL. Dosya başına × odak başına bir denetleyici.",
    "lenses": ["integrity", "security", "performance"],
    "method": "adversarial — kusur ARA (default: kusurlu); her bulguda mitigation'ın kod-kanıtıyla gerçekten YOK olduğunu doğrula (false-positive ele); etkiyi persisted-state geri-okuyarak gözle (HTTP status yetmez).",
    "disposition": "bulgu seam-fixable (orkestrasyon: ordering/try-catch/bağlanmamış üye/eksik state-alanı) → düzelt + tüm loop'u yeniden koş (bounded retry). Yapısal (gen/** entity·config | manifest declaration | Code/ host) → seam DÜZELTEMEZ (improvise YASAK) → GAP → gap-protocol → upstream'e route.",
    "pass": "üç lens'te de açık seam-fixable bulgu = 0 (yapısal GAP'ler route+rapor edilir, 'fix' SAYILMAZ). LLM-judge DEĞİL: Kapı 3 'seam doğru' demez, 'şu defect-sınıfı var/yok' der — conformance'ın (contract-fidelity) yerini ALMAZ, bilinen defect-sınıflarına EK savunma katmanıdır."
  }
}
